body
    .el-message .el-message-icon--success
                    color:var(--el-color-primary)
    .el-message--success .el-message__content
                             color:var(--el-color-primary)
    .el-form--label-top .el-form-item__label
        padding: 0 0 4px 0

    .el-table--medium th, .el-table--medium td
        padding: 8px 0

    .el-pagination
        font-size: 14px
        margin-top: 0
        color:#999
    .el-pagination span:not([class*=suffix]), .el-pagination button
        margin-left: 0

    .el-form-item--small .el-form-item__error
        margin-bottom: 4px

        span
            color: #03B472

    .el-menu-item.is-active
        background-color: rgb(242, 244, 246)
        border-right:1px solid rgb(22, 119, 255);
        span
            color: #03B472

    .el-message-box__message p, .el-notification__content p
        word-break: break-all

    .el-message-box__header
        // background-color: #eee

        .el-message-box__title
            font-size: 14px

    .el-button--mini
        padding: 7px 15px 6px

@media screen and (max-width: 1366px)
    .el-submenu>.el-submenu__title>span
        font-size: 13px

    body
        .el-switch__label *
            font-size: 12px

        .common-list-table
            // font-size: 12px

            // th
            //     font-size: 12px

            th, td
                padding: 4px 0

        // .el-form-item__label
        //     font-size: 12px

        // .el-checkbox__label
        //     font-size: 12px

        .el-dialog__title
            font-size: 15px

        .el-form--label-top
            .el-form-item--small.el-form-item
                margin-bottom: 8px

    .el-submenu>.el-submenu__title>span
        font-size: 13px

    .el-submenu .el-menu-item span
        font-size: 13px

.el-dialog
    .el-form
        .row
            display: flex
            justify-content: space-between

    .el-select
        width: 100%

body .el-message
    min-width: 0

.el-loading-mask .el-icon-loading
    font-size: 0.32rem

.el-message__icon
    font-size: 16px

.el-dialog__footer
    font-size: 14px

.el-date-editor .el-range-input
    margin-left: 2px

// .div-query
// .el-form--inline
// display: flex
// .el-form-item
// display: flex
.div-query .el-form--inline .el-form-item__content
    .el-input
        // max-width: 150px;

    .el-date-editor--daterange
        max-width: 300px

body .el-submenu__title
    height: 48px
    line-height: 48px

    i
        font-size: 14px

    &:hover
        background-color: transparent

        >span, i
            color: #03B472

.tab-page
    display: flex
    flex-direction: column

    .el-menu-demo
        padding-left: 28px

        .el-menu-item
            padding: 0
            margin-right: 20px

    .el-menu-item.is-active
        background-color: transparent

    .div-body
        flex: 1
        overflow: auto

        > div
            height: 100%

.app-main div.Craw
    .el-dialog__body .el-form-item--mini.el-form-item
        margin-bottom: 14px

.el-form-item--mini .el-form-item__error
    margin-top: 2px

@media screen and (max-width: 1280px)
    .app-main div.Craw
        .page-box .head .div-query .el-input__inner
            width: 120px

        .page-box .head .div-query .el-form--inline .el-form-item
            margin-right: 8px

        .page-box .head .div-query .el-form--inline .el-form-item:last-child
            margin-right: 0

        .crawlerIndex .head
            padding: 0 22px 10px

        .el-menu-demo
            padding-left: 20px